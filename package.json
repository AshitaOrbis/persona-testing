{
  "name": "persona-testing",
  "version": "0.2.5",
  "description": "AI persona testing framework. Define user personas, run automated UX testing with browser automation.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "persona-testing": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "tsx src/parser.test.ts",
    "test:ai": "claude -p 'run npm test in this project and report the results'"
  },
  "keywords": [
    "testing",
    "persona",
    "ux",
    "ai",
    "automation",
    "playwright",
    "browser-testing",
    "llm"
  ],
  "author": "Ashita Orbis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AshitaOrbis/persona-testing.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0",
    "playwright": "^1.49.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
